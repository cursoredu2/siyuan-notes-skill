# 思源笔记API配置
# 复制此文件为 .env 并填入实际配置

# 思源笔记服务器地址 (默认: localhost)
SIYUAN_HOST=localhost

# 思源笔记端口号 (默认: 6806，如果使用HTTPS且无特殊端口可留空)
SIYUAN_PORT=6806

# 是否使用HTTPS (true/false，默认: false)
SIYUAN_USE_HTTPS=false

# API Token (在思源笔记设置→关于→API Token中获取)
SIYUAN_API_TOKEN=your_api_token_here

# HTTP Basic Auth 用户名 (如果启用了Basic Auth)
SIYUAN_BASIC_AUTH_USER=

# HTTP Basic Auth 密码 (如果启用了Basic Auth)
SIYUAN_BASIC_AUTH_PASS=

# 排除的笔记本ID (多个用逗号分隔，API层面过滤)
# 示例: SIYUAN_EXCLUDE_BOXES=20210816161940-xxxxxxx,20210816161941-yyyyyyy
# 获取笔记本ID: SELECT DISTINCT box FROM blocks
SIYUAN_EXCLUDE_BOXES=

# 排除的笔记路径 (多个用逗号分隔，API层面过滤，包含子笔记)
# 示例: SIYUAN_EXCLUDE_PATHS=/私密笔记,/个人日记
# 注意: 路径以 / 开头，会排除该笔记及其所有子笔记
SIYUAN_EXCLUDE_PATHS=